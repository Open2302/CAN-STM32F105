<Debugger>
	<Debug>
		<Arch>Cortex-M3</Arch>
		
		<SWD support="true">
			<ExpectedID>0x2BA01477</ExpectedID>
		</SWD>
		
		<JTAG support="true">
			<TAP name="ARM CoreSight JTAG-DP"    irLen="4" ircapture="0x1" irmask="0xF" irIDCode="0xE" select="true">
				<ExpectedID>0x4BA00477</ExpectedID>
			</TAP>		
		</JTAG>
		
		<Reset>
			<HwReset       support="true" />
			<SoftSysReset  support="true" />
			<SoftVectReset support="true" select="true"/>
		</Reset>
		
		<SystemResetClkFreq>8000000</SystemResetClkFreq> <!-- HSI 8MHZ -->
	</Debug>

	<!-- 
		Memory Blocks that can be read/written/executed
		exclude ram,rom blocks
		read(true,false)
		write(true,false)
		execute(true,false)	
	 -->
	<MemMap>
		<Block addr="0xE0000000" size="0xFFFFF"  read="true"   write="true"   execute="false" name="System" />
		<!-- Block addr="0x60000000" size="0x9000000" read="true"   write="true"   execute="true" name="external SRAM" -->
		<Block addr="0x400E0000" size="0x2600"   read="true"   write="true"   execute="false" name="System Controller" />
		<Block addr="0x400B0000" size="0x4000"   read="true"   write="true"   execute="false" name="DMAC" />
		<Block addr="0x400AC000" size="0x4000"   read="true"   write="true"   execute="false" name="ADC" />
		<Block addr="0x400A8000" size="0x4000"   read="true"   write="true"   execute="false" name="ADC12B" />
		<Block addr="0x400A4000" size="0x4000"   read="true"   write="true"   execute="false" name="UDPHS" />
		<Block addr="0x40090000" size="0x10000"  read="true"   write="true"   execute="false" name="USART0/1/2/3" />
		<Block addr="0x4008C000" size="0x4000"   read="true"   write="true"   execute="false" name="PWM" />
		<Block addr="0x40088000" size="0x4000"   read="true"   write="true"   execute="false" name="TWI1" />
		<Block addr="0x40084000" size="0x4000"   read="true"   write="true"   execute="false" name="TWI0" />
		<Block addr="0x40080000" size="0x4000"   read="true"   write="true"   execute="false" name="TC0/1/2" />
		<Block addr="0x40008000" size="0x4000"   read="true"   write="true"   execute="false" name="SSC" />
		<Block addr="0x40000000" size="0x4000"   read="true"   write="true"   execute="false" name="MCI" />
		
		<!--Block addr="0x20100000" size="0x1000"   read="true"   write="true"   execute="false" name="IRAM NFC" / -->			
		<Block addr="0x20180000" size="0x80000"   read="true"   write="true"   execute="false" name="IRAM UDPHS" />		
		<Block addr="0x22000000" size="0x2000000" read="true"   write="true"   execute="false" name="IRAM 32M bit band" />	
		<Block addr="0x00000000" size="0x80000"   read="true"   write="false"  execute="true"  name="BOOT memory remap" />	<!-- Change the Size basic on the boot config-->
		
	</MemMap>
</Debugger>
