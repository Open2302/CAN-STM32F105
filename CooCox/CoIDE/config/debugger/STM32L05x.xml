<Debugger>
	<Debug>
		<Arch>Cortex-M0</Arch>
		
		<SWD support="true">
			<ExpectedID>0x0BC11477</ExpectedID>
		</SWD>
		
		<JTAG support="false">		
		</JTAG>
				
		<Reset>
			<HwReset       support="true" />
			<SoftSysReset  support="true" select="true"/>
			<SoftVectReset support="true" />
		</Reset>
		
		<SystemResetClkFreq>16000000</SystemResetClkFreq> 
	</Debug>

	<!-- 
		Memory Blocks that can be read/written/executed
		exclude ram,rom blocks
		read(true,false)
		write(true,false)
		execute(true,false)	
	 -->
	<MemMap>
		<!-- <Block addr="" size="" read="true"   write="true"   execute="false" name="" /> -->
		
		<!-- Private peripheral bus - External -->
		<Block addr="0xE00FF000" size="0x1000"   read="true"   write="true"   execute="false" name="ROM Table" />
		<Block addr="0xE0042000" size="0xD000"   read="true"   write="true"   execute="false" name="External PPB" />
		<Block addr="0xE0041000" size="0x1000"   read="true"   write="true"   execute="false" name="ETM" />
		<Block addr="0xE0040000" size="0x1000"   read="true"   write="true"   execute="false" name="TPIU" />
		
		<!-- Private peripheral bus - Internal-->
		<Block addr="0xE000E000" size="0x1000"   read="true"   write="true"   execute="false" name="System Control Space" />
		<Block addr="0xE0002000" size="0x1000"   read="true"   write="true"   execute="false" name="FPB" />
		<Block addr="0xE0001000" size="0x1000"   read="true"   write="true"   execute="false" name="DWT" />
		<Block addr="0xE0000000" size="0x1000"   read="true"   write="true"   execute="false" name="ITM" />
		
		<!-- IOPORT -->		
		<Block addr="0x50001C00" size="0x400" read="true"   write="true"   execute="false" name="GPIOH" />
		<Block addr="0x50000C00" size="0x400" read="true"   write="true"   execute="false" name="GPIOD" />
		<Block addr="0x50000800" size="0x400" read="true"   write="true"   execute="false" name="GPIOC" />
		<Block addr="0x50000400" size="0x400" read="true"   write="true"   execute="false" name="GPIOB" />
		<Block addr="0x50000000" size="0x400" read="true"   write="true"   execute="false" name="GPIOA" />
		
		<!-- AHB -->	
		<Block addr="0x40026000" size="0x400" read="true"   write="true"   execute="false" name="AES" />
		<Block addr="0x40025000" size="0x400" read="true"   write="true"   execute="false" name="RNG" />
		<Block addr="0x40024000" size="0x400" read="true"   write="true"   execute="false" name="TSC" />
		<Block addr="0x40023000" size="0x400" read="true"   write="true"   execute="false" name="CRC" />
		<Block addr="0x40022000" size="0x400" read="true"   write="true"   execute="false" name="FLASH" />
		<Block addr="0x40021000" size="0x400" read="true"   write="true"   execute="false" name="RCC" />
		<Block addr="0x40020000" size="0x400" read="true"   write="true"   execute="false" name="DMA1" />
		
		<!-- APB -->			
		<Block addr="0x40015800" size="0x400" read="true"   write="true"   execute="false" name="DBG" />
		<Block addr="0x40013800" size="0x400" read="true"   write="true"   execute="false" name="USART1" />
		<Block addr="0x40013000" size="0x400" read="true"   write="true"   execute="false" name="SPI1" />
		<Block addr="0x40012400" size="0x400" read="true"   write="true"   execute="false" name="ADC1" />
		<Block addr="0x40011C00" size="0x400" read="true"   write="true"   execute="false" name="FIREWALL" />
		<Block addr="0x40011400" size="0x400" read="true"   write="true"   execute="false" name="TIM22" />
		<Block addr="0x40010800" size="0x400" read="true"   write="true"   execute="false" name="TIM21" />
		<Block addr="0x40010400" size="0x400" read="true"   write="true"   execute="false" name="EXT1" />
		<Block addr="0x40010000" size="0x400" read="true"   write="true"   execute="false" name="SYSCFG" />
		<Block addr="0x4007C000" size="0x400" read="true"   write="true"   execute="false" name="LPTIM1" />
		<Block addr="0x40007400" size="0x400" read="true"   write="true"   execute="false" name="DAC1" />
		<Block addr="0x40007000" size="0x400" read="true"   write="true"   execute="false" name="PWR" />
        <Block addr="0x40006C00" size="0x400" read="true"   write="true"   execute="false" name="CRS" />
        <Block addr="0x40006000" size="0x800" read="true"   write="true"   execute="false" name="USB(SRAM 512*16BIT)" />
        <Block addr="0x40005C00" size="0x400" read="true"   write="true"   execute="false" name="USB FS" />
		<Block addr="0x40005800" size="0x400" read="true"   write="true"   execute="false" name="I2C2" />
		<Block addr="0x40005400" size="0x400" read="true"   write="true"   execute="false" name="I2C1" />
		<Block addr="0x40004800" size="0x400" read="true"   write="true"   execute="false" name="LPUART1" />
		<Block addr="0x40004400" size="0x400" read="true"   write="true"   execute="false" name="USART2" />
		<Block addr="0x40003800" size="0x400" read="true"   write="true"   execute="false" name="SPI2" />
		<Block addr="0x40003000" size="0x400" read="true"   write="true"   execute="false" name="IWDG" />
		<Block addr="0x40002C00" size="0x400" read="true"   write="true"   execute="false" name="WWDG" />
		<Block addr="0x40002800" size="0x400" read="true"   write="true"   execute="false" name="RTC+BKP_REG" />
		<Block addr="0x40001000" size="0x400" read="true"   write="true"   execute="false" name="TIMER6" />
		<Block addr="0x40000000" size="0x400" read="true"   write="true"   execute="false" name="TIMER2" />
		
		
		<Block addr="0x20000000" size="0x2000" read="true"   write="false"   execute="true" name="SRAM" />
		<Block addr="0x1FF80000" size="0x1000+32" read="true"   write="false"   execute="true" name="Option bytes" />	
		<Block addr="0x08000000" size="0x10000" read="true"   write="false"  execute="true"  name="Flash program memory" />
		<Block addr="0x08080000" size="0x800" read="true"   write="false"  execute="true"  name="Data EEPROM" />
		<Block addr="0x00000000" size="0x10000" read="true"   write="false"  execute="true"  name="BOOT memory remap" />	<!-- Change the Size basic on the boot config-->
	</MemMap>
</Debugger>
