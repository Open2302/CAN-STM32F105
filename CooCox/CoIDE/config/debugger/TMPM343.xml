<Debugger>
    <Debug>
        <Arch>Cortex-M3</Arch>
        <SWD support="true">
            <ExpectedID>0x1BA01477</ExpectedID>
            <ExpectedID>0x2BA01477</ExpectedID>
        </SWD>
        <JTAG support="true">
            <TAP name="ARM CoreSight JTAG-DP" irLen="4" ircapture="0x1" irmask="0xF" irIDCode="0xE" select="true">
                <ExpectedID>0x3BA00477</ExpectedID>
                <ExpectedID>0x4BA00477</ExpectedID>
            </TAP>
        </JTAG>
        <Reset>
            <HwReset support="true" />
            <SoftSysReset support="true" select="true" />
            <SoftVectReset support="true" />
        </Reset>
        <SystemResetClkFreq>50000000</SystemResetClkFreq>
        <!-- HSI 50MHZ -->
    </Debug>
    <!-- 
		Memory Blocks that can be read/written/executed
		exclude ram,rom blocks
		read(true,false)
		write(true,false)
		execute(true,false)	
	 -->
    <MemMap>
        <Block addr="0xE00FF000" size="0x1000" read="true" write="true" execute="false" name="ROM Table" />
        <Block addr="0xE0042000" size="0xD000" read="true" write="true" execute="false" name="External PPB" />
        <Block addr="0xE0041000" size="0x1000" read="true" write="true" execute="false" name="ETM" />
        <Block addr="0xE0040000" size="0x1000" read="true" write="true" execute="false" name="TPIU" />
        <!--  Private peripheral bus - Internal -->
        <Block addr="0xE000E000" size="0x1000" read="true" write="true" execute="false" name="System Control Space" />
        <Block addr="0xE0002000" size="0x1000" read="true" write="true" execute="false" name="FPB" />
        <Block addr="0xE0001000" size="0x1000" read="true" write="true" execute="false" name="DWT" />
        <Block addr="0xE0000000" size="0x1000" read="true" write="true" execute="false" name="ITM" />
        <!--  FiRM Peripherals -->
        <Block addr="0x40000000" size="0x1000" read="true" write="true" execute="false" name="DMA UnitA" />
		<Block addr="0x40001000" size="0x1000" read="true" write="true" execute="false" name="DMA UnitB" />
		<Block addr="0x40002000" size="0x1000" read="true" write="true" execute="false" name="DMA UnitC" />
		<Block addr="0x40040000" size="0x10000" read="true" write="true" execute="false" name="Reserved" />
		<Block addr="0x40050000" size="0xF000" read="true" write="true" execute="false" name="ADC" />
		<Block addr="0x4005F000" size="0x1000" read="true" write="true" execute="false" name="Reserved" />
		<Block addr="0x40060000" size="0x1E000" read="true" write="true" execute="false" name="EPHC Ch0,1" />
		<Block addr="0x4007E000" size="0x1D000" read="true" write="true" execute="false" name="EPHC Ch2" />
		<Block addr="0x4009B000" size="0x1000" read="true" write="true" execute="false" name="TSPI Ch3" />
		<Block addr="0x4009C000" size="0x24000" read="true" write="true" execute="false" name="TSPI Ch4" />
