<Debugger>
	<Debug>
		<Arch>Cortex-M0</Arch>
		
		<SWD support="true">
			<ExpectedID>0x0BB11477</ExpectedID>
		</SWD>
		
		<JTAG support="false">	
		</JTAG>
		
		<Reset>
			<HwReset       support="true" />
			<SoftSysReset  support="true" select="true"/>
			<SoftVectReset support="true" />
		</Reset>
		
		<SystemResetClkFreq>8000000</SystemResetClkFreq> <!-- HSI 8MHZ -->
	</Debug>

	<!-- 
		Memory Blocks that can be read/written/executed
		exclude ram,rom blocks
		read(true,false)
		write(true,false)
		execute(true,false)	
	 -->
	<MemMap>
		<!-- <Block addr="" size="" read="true"   write="true"   execute="false" name="" /> -->
		<Block addr="0xE000ED00" size="0x0090"   read="true"   write="true"   execute="false" name="System Control" />
		<Block addr="0xE000E100" size="0xC000"   read="true"   write="true"   execute="false" name="External Interrupt Controller" />
		<Block addr="0xE000E010" size="0x0F00"   read="true"   write="true"   execute="false" name="System timer" />
		
		<Block addr="0x40150000" size="0x4000"   read="true"   write="true"   execute="false" name="UART 1" />
		<Block addr="0x40140000" size="0x4000"   read="true"   write="true"   execute="false" name="PWM 4/5/6/7" />	
		<Block addr="0x40110000" size="0x4000"   read="true"   write="true"   execute="false" name="Timer 2/3" />
		<Block addr="0x400E0000" size="0x10000"  read="true"   write="true"   execute="false" name="ADC" />
		<Block addr="0x40050000" size="0x4000"   read="true"   write="true"   execute="false" name="UART 0" />
		<Block addr="0x40040000" size="0x4000"   read="true"   write="true"   execute="false" name="PWM0/1/2/3" />
		<Block addr="0x40034000" size="0x4000"   read="true"   write="true"   execute="false" name="SPI 1" />
		<Block addr="0x40030000" size="0x4000"   read="true"   write="true"   execute="false" name="SPI 0" />
		<Block addr="0x40020000" size="0x4000"   read="true"   write="true"   execute="false" name="I2C" />
		<Block addr="0x40010000" size="0x4000"   read="true"   write="true"   execute="false" name="Timer 0/1" />
		<Block addr="0x40004000" size="0x4000"   read="true"   write="true"   execute="false" name="WDT" />
		
		<Block addr="0x60000000" size="0x20000"  read="true"   write="true"   execute="false" name="EBI" />
		
		<Block addr="0x50010000" size="0x4000"   read="true"   write="true"   execute="false" name="EBI control" />
		<Block addr="0x5000C000" size="0x4000"   read="true"   write="true"   execute="false" name="FMC" />
		<Block addr="0x50004000" size="0x4000"   read="true"   write="true"   execute="false" name="GPIO 0~4" />
		<Block addr="0x50000300" size="0x0400"   read="true"   write="true"   execute="false" name="INT" />
		<Block addr="0x50000200" size="0x0100"   read="true"   write="true"   execute="false" name="Clock control" />
		<Block addr="0x50000000" size="0x0200"   read="true"   write="true"   execute="false" name="System Global" />
	</MemMap>
</Debugger>
