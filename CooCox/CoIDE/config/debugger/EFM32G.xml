<Debugger>
	<Debug>
		<Arch>Cortex-M3</Arch>
		
		<SWD support="true">
			<ExpectedID>0x2BA01477</ExpectedID>
		</SWD>
		<JTAG support="false">	
		</JTAG>
		
		<Reset>
			<HwReset       support="true"  />
			<SoftSysReset  support="true" select="true"/>
			<SoftVectReset support="true" />
		</Reset>
		
		<SystemResetClkFreq>14000000</SystemResetClkFreq> <!-- HSI 8MHZ -->
	</Debug>

	<!-- 
		Memory Blocks that can be read/written/executed
		exclude ram,rom blocks
		read(true,false)
		write(true,false)
		execute(true,false)	
	 -->
	<MemMap>
		<!-- <Block addr="" size="" read="true"   write="true"   execute="false" name="" /> -->
		
		<!-- Private peripheral bus - External -->
		<Block addr="0xE00FF000" size="0x1000"   read="true"   write="true"   execute="false" name="ROM Table" />
		<Block addr="0xE0042000" size="0xD000"   read="true"   write="true"   execute="false" name="External PPB" />
		<Block addr="0xE0041000" size="0x1000"   read="true"   write="true"   execute="false" name="ETM" />
		<Block addr="0xE0040000" size="0x1000"   read="true"   write="true"   execute="false" name="TPIU" />
		
		<!-- Private peripheral bus - Internal-->
		<Block addr="0xE000E000" size="0x1000"   read="true"   write="true"   execute="false" name="System Control Space" />
		<Block addr="0xE0002000" size="0x1000"   read="true"   write="true"   execute="false" name="FPB" />
		<Block addr="0xE0001000" size="0x1000"   read="true"   write="true"   execute="false" name="DWT" />
		<Block addr="0xE0000000" size="0x1000"   read="true"   write="true"   execute="false" name="ITM" />
		
		<!-- Core Peripherals -->
		<Block addr="0x400E0000" size="0x400"   read="true"   write="true"   execute="false" name="AES" />
		<Block addr="0x400CC000" size="0x400"   read="true"   write="true"   execute="false" name="PRS" />
		<Block addr="0x400CA000" size="0x400"   read="true"   write="true"   execute="false" name="RMU" />
		<Block addr="0x400C8000" size="0x400"   read="true"   write="true"   execute="false" name="CMU" />
		<Block addr="0x400C6000" size="0x400"   read="true"   write="true"   execute="false" name="EMU" />
		<Block addr="0x400C2000" size="0x400"   read="true"   write="true"   execute="false" name="DMA" />
		<Block addr="0x400C0000" size="0x400"   read="true"   write="true"   execute="false" name="MSC" />
		
		<!-- Low Energy Peripherals -->
		<Block addr="0x4008A000" size="0x400"   read="true"   write="true"   execute="false" name="LCD" />
		<Block addr="0x40088000" size="0x400"   read="true"   write="true"   execute="false" name="WDOG" />
		<Block addr="0x40086800" size="0x400"   read="true"   write="true"   execute="false" name="PCNT2" />
		<Block addr="0x40086400" size="0x400"   read="true"   write="true"   execute="false" name="PCNT1" />
		<Block addr="0x40086000" size="0x400"   read="true"   write="true"   execute="false" name="PCNT0" />
		<Block addr="0x40084400" size="0x400"   read="true"   write="true"   execute="false" name="LEUART1" />
		<Block addr="0x40084000" size="0x400"   read="true"   write="true"   execute="false" name="LEUART0" />
		<Block addr="0x40082000" size="0x400"   read="true"   write="true"   execute="false" name="LETIMER0" />
		<Block addr="0x40080000" size="0x400"   read="true"   write="true"   execute="false" name="RTC" />
		
		<!-- Peripherals -->
		<Block addr="0x40010800" size="0x400"   read="true"   write="true"   execute="false" name="TIMER2" />
		<Block addr="0x40010400" size="0x400"   read="true"   write="true"   execute="false" name="TIMER1" />
		<Block addr="0x40010000" size="0x400"   read="true"   write="true"   execute="false" name="TIMER0" />
