		<Block addr="0x4000C800" size="0x400"   read="true"   write="true"   execute="false" name="USART2" />
		<Block addr="0x4000C400" size="0x400"   read="true"   write="true"   execute="false" name="USART1" />
		<Block addr="0x4000C000" size="0x400"   read="true"   write="true"   execute="false" name="USART0" />
		<Block addr="0x4000A000" size="0x400"   read="true"   write="true"   execute="false" name="I2C0" />
		<Block addr="0x40008000" size="0x400"   read="true"   write="true"   execute="false" name="EBI" />
