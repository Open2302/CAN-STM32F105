		<Block addr="0x40001400" size="0x400"   read="true"   write="true"   execute="false" name="ACMP1" />
		<Block addr="0x40001000" size="0x400"   read="true"   write="true"   execute="false" name="ACMP0" />
		<Block addr="0x40000000" size="0x400"   read="true"   write="true"   execute="false" name="VCMP" />
			
	</MemMap>
</Debugger>
