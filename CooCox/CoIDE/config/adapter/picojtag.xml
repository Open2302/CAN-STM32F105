<adapter>
	<Name>picoJTAG</Name>
	<Vendor>picoJTAG</Vendor>
	<Debugger>
		<Set>FTDI</Set>
		<Driver>IFTD2xx.dll</Driver>
		<JTAG support="true">
			<transaction name="open"  mask="0x6E2B" value="0x2A28" /> 
			<transaction name="reset" mask="0x002B" value="0x0008" /> 
			<transaction name="busy"  mask="0x0000" value="0x0000" />
			<transaction name="close" mask="0x6E2B" value="0x4E28" />
		</JTAG>

		<SWD support="false">
		</SWD>
	</Debugger>
</adapter>
