<adapter>
	<Name>Amontec-JTAGkey</Name>
	<Vendor>amontec</Vendor>
	<Debugger>
		<Set>FTDI</Set>
		<Driver>IFTD2xx.dll</Driver>
		<JTAG support="true">
			<transaction name="open"  mask="0x0C1B" value="0x0C08" /> 
			<transaction name="reset" mask="0x0E1B" value="0x0400" /> 
			<transaction name="busy"  mask="0x0000" value="0x0000" />
			<transaction name="close" mask="0x0C1B" value="0x0C18" />
		</JTAG>

		<SWD support="false">
		</SWD>
	</Debugger>
</adapter>
