<adapter>
	<Name>NGX-USB-JTAG</Name>
	<Vendor>NGX</Vendor>
	<Debugger>
		<Set>FTDI</Set>
		<Driver>IFTD2xx.dll</Driver>
		<JTAG support="true">
			<transaction name="open"  mask="0x0F1B" value="0x0608" /> 
			<transaction name="reset" mask="0x0F00" value="0x0200" /> 
			<transaction name="busy"  mask="0x0000" value="0x0000" />
			<transaction name="close" mask="0x0210" value="0x0200" />
		</JTAG>

		<SWD support="false">
		</SWD>
	</Debugger>
</adapter>
